# AI 大赛报名系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值

# ==================== 服务器配置 ====================
# 服务运行端口
PORT=3000

# ==================== 飞书机器人配置 ====================
# 飞书机器人 Webhook URL
# 获取方式：在飞书群中添加自定义机器人，复制 Webhook 地址
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-key

# ==================== 飞书应用凭证 ====================
# 飞书开放平台应用 ID
# 获取方式：https://open.feishu.cn/ -> 企业管理 -> 应用开发 -> 创建应用
FEISHU_APP_ID=cli_your_app_id

# 飞书开放平台应用密钥
# 获取方式：应用详情 -> 凭证管理 -> 应用密钥
FEISHU_APP_SECRET=your_app_secret

# ==================== 飞书多维表格配置 ====================
# 多维表格应用 token（从飞书多维表格 URL 获取）
# URL 格式：https://xxx.feishu.cn/base/{app_token}?table={table_id}
# 获取方式：打开飞书多维表格，从 URL 中复制 /base/ 后面的部分
FEISHU_BITABLE_APP_TOKEN=your_app_token

# 报名表表格 ID（以 tbl 开头）
# 获取方式：表格 ID 在 URL 的 ?table= 参数中，或以 tbl 开头
# 报名表表格 ID: tbltDHBoAs72cFnh
FEISHU_REGISTRATION_TABLE_ID=tbltDHBoAs72cFnh

# 成果提交表格 ID（以 tbl 开头）
# 获取方式：表格 ID 在 URL 的 ?table= 参数中，或以 tbl 开头
# 成果提交表格 ID: tblxYsQVComD9wRW
FEISHU_SUBMISSION_TABLE_ID=tblxYsQVComD9wRW

# ==================== 配置说明 ====================
# 1. 必须配置 FEISHU_APP_ID 和 FEISHU_APP_SECRET 才能使用飞书 API
# 2. FEISHU_BOT_WEBHOOK 可选，不配置则不发送机器人通知
# 3. FEISHU_BITABLE_APP_TOKEN：打开飞书多维表格，从 URL 中复制 /base/ 后面的部分
#    例如：https://xxx.feishu.cn/base/AbCdEfGhIjKlMnOp?table=tbltDHBoAs72cFnh
#         则 APP_TOKEN = AbCdEfGhIjKlMnOp
# 4. 表格 ID：以 tbl 开头，在 URL 的 ?table= 参数中
# 5. 确保飞书应用已开通以下权限：
#    - 获取租户 access_token (tenant_access_token)
#    - 多维表格数据读写 (bitable:app)
#    - 发送消息到群组 (im:message)
